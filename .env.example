# Optional. Leave unset in development: the Vite dev server proxies /auth,
# /users and /flights to the backend (see vite.config.ts), so requests stay
# same-origin and no CORS config is needed on the backend.
#
# Set this only to hit the backend directly (e.g. a deployed API). The backend
# must then allow CORS from this frontend's origin.
# VITE_API_URL=http://localhost:8080
